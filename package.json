{
  "name": "@gvamaresh/mdflow",
  "version": "1.0.1",
  "description": "Lightweight Markdown rendering for React without the bloat of deprecated NPM modules. Built for speed and deep UI control using modern TypeScript",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "keywords": [
    "markdown",
    "react",
    "mdflow",
    "converter",
    "markdown-parser",
    "react-component",
    "typescript",
    "zero-dependencies",
    "markdown-to-react",
    "web-development",
    "frontend-tools"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --external react",
    "dev": "tsup src/index.ts --watch --external react",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "author": "Amaresh Hebba",
  "license": "Apache-2.0",
  "type": "commonjs",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gvamaresh/mdflow.git"
  },
  "bugs": {
    "url": "https://github.com/gvamaresh/mdflow/issues"
  },
  "homepage": "https://github.com/gvamaresh/mdflow#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
